{% extends 'base.html.twig' %}

{% block title %}Page produit
{% endblock %}

{% block body %}
	<div class="container">
	<br>
	<br>
		<div class="card mb-12">
			<div class="row g-0">
				<div class="col-md-3 mt-3">
					<img src="{{ asset('images/'~product.image) }}" class="img-fluid rounded-start" alt="">
				</div>
				<div class="col-md-8">
					<div class="card-body">
						<h1 class="card-title">{{ product.name }}</h1>
						<p>{{ product.description }}</p>
						<h3>{{ product.price }}
								€</h3>
						<a href="{{ path('app_cart_new',{'id':product.id}) }}" class="btn btn-outline-success">Ajouter au panier</a>
						<p class="card-text">
							<small class="text-body-secondary">Last updates 3 min ago</small>
						</p>
					</div>
				</div>
			</div>
		</div>
		<br><br><br>
        <h2>Derniers produits ajoutés</h2>
        <div class="row">
			{% for product in products %}
				<div class="col-md-3 mt-4">
					<div class="card" style="width: 18rem;">
						<img src="{{ asset('images/'~product.image)}}" class="imgproduct card-img-top" alt="image des produits">
						<div class="card-body">
							<a class="titleProductLink" href="{{ path('app_home_product_show',{'id':product.id}) }} "><h5 class="card-title titleProduct">{{ product.name }}</h5></a>
							<p class="card-text">{{ product.Description|slice(0,60) }}</p>
							<h3>{{ product.price }} €</h3>
							<a href="#" class="btn btn-outline-success">Ajouter au panier</a>
						</div>
					</div>
				</div>
			{% endfor %}
		</div>
	</div>
{% endblock %}
