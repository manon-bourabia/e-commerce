{% extends 'base.html.twig' %} {% block title %}Accueil - Boutique{% endblock %}
{% block body %}
<div class="bg-light py-5 mb-5 shadow-sm">
    <div class="container text-center">
        <h1 class="display-4 fw-bold">Nos Produits</h1>
    </div>
</div>

<div class="container">
    <div class="row">
        {% for product in products %}
        <div class="col-lg-3 col-md-4 col-sm-6 mb-4">
            <div class="card h-100 border-0 shadow-sm custom-card">
                <div
                    class="position-relative overflow-hidden"
                    style="height: 200px"
                >
                    <img
                        src="{{ asset('images/' ~ product.image) }}"
                        class="card-img-top h-100 w-100"
                        style="object-fit: cover"
                        alt="{{ product.name }}"
                    />
                </div>

                <div class="card-body d-flex flex-column">
                    <a
                        class="text-decoration-none text-dark"
                        href="{{ path('app_home_product_show',{'id':product.id}) }}"
                    >
                        <h5 class="card-title fw-bold mb-2">
                            {{ product.name }}
                        </h5>
                    </a>

                    <p class="card-text text-muted small flex-grow-1">
                        {{ product.Description|slice(0,60) }}...
                    </p>

                    <div
                        class="d-flex justify-content-between align-items-center mt-3"
                    >
                        <span class="h4 fw-bold text-primary mb-0">
                            {{ product.price|number_format(2, ',', ' ') }} €
                        </span>
                    </div>
                    <div class="d-grid mt-3">
                        <a
                            href="{{ path('app_cart_new', {'id': product.id}) }}"
                            class="btn btn-primary w-100"
                        >
                            Ajouter au panier
                        </a>
                    </div>
                </div>
            </div>
        </div>
        {% endfor %}
    </div>

    <div class="d-flex justify-content-center mt-5">
        {{
        knp_pagination_render(products,'layouts/pagination_template.html.twig')
        }}
    </div>
</div>
{% endblock %}
