{% if pageCount > 1 %}
    <nav aria-label="...">
        <ul class="pagination paginationButton">
        {% if previous is defined %}
            <li class="page-item">
            <a href="{{path(route, query|merge ({(pageParameterName):previous}))}}" class="page-link">Previous</a></li>
        {% endif %}
        {% for page in pagesInRange %}
        <li class="page-item active" aria-current="page">
        <a href="{{path(route, query|merge ({(pageParameterName):page}))}}" class="page-link">{{page}}</a>
        </li>
        {% else %}
            <li class="page-item active" aria-current="page">
            <a href="background: green" class="page-link" href="{{path(route, query|merge ({(pageParameterName):page}))}}" class="page-link"></a>
        {% endfor %}
        {% if next is defined %}
            <li class="page-item">
            <a class="page-link" href="{{path(route, query|merge ({(pageParameterName):next}))}}" class="page-link">Next</a></li>
        {% endif %}
        </ul>
    </nav>
{% endif %}