{% if pageCount > 1 %}
	<nav aria-label="Page navigation example">
		<ul class="pagination">
			{% if previous is defined %}
				<li class="page-item">
					<a class="page-link" href="{{ path(route, query|merge({(pageParameterName): previous})) }}">Précedent</a>
				</li>
				{% for page in pagesInRange %}
					{% if page != current %}
						<li class="page-item active" aria-current="page">
							<a class="page-link" href="{{ path(route, query|merge({(pageParameterName):page})) }}">{{ page }}</a>
						</li>
					{% else %}
						<li class="page-item active" aria-current="page">
							<a style="background: purple" class="page-link" href="{{ path(route, query|merge({(pageParameterName):page})) }}">{{ page }}></a>
						</li>
					{% endif %}
				{% endfor %}
				{# <li class="page-item">
													<a class="page-link" href="#">1</a>
												</li>
												<li class="page-item">
													<a class="page-link" href="#">2</a>
												</li>
												<li class="page-item">
													<a class="page-link" href="#">3</a>
												</li> #}
			{% endif %}
			{% if next is defined %}
				<li class="page-item">
					<a class="page-link" href="{{ path(route, query|merge({(pageParameterName): next})) }}">Suivant</a>
				</li>
			{% endif %}
		</ul>
	</nav>
{% endif %}
