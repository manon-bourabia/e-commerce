{% extends 'base.html.twig' %} 

{% block title %}Ville{% endblock %} 

{% block body %}

<div class="container">
    <h1>Ville</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ city.id }}</td>
            </tr>
            <tr>
                <th>Nom</th>
                <td>{{ city.name }}</td>
            </tr>
            <tr>
                <th>Frais de port</th>
                <td>{{ city.shippingCost }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_city_index') }}">Retour à la liste</a>

    <a href="{{ path('app_city_edit', {'id': city.id}) }}">Modifier</a>

    {{ include('city/_delete_form.html.twig') }}
</div>
{% endblock %}
