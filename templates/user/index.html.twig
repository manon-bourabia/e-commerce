{% extends 'base.html.twig' %}

{% block title %}Utilisateur
{% endblock %}

{% block body %}
	<div class="container">
		<h1>Liste des utilisateurs</h1>
		{% include 'layouts/_flash_message.html.twig' %}

		<table class="table">
			<tr>
				<th>id</th>
				<th>Nom</th>
				<th>Prénom</th>
				<th>Email</th>
				<th>Rôle</th>
				<th>Action</th>
			</tr>
			{% for user in users %}
				<tr>
					<td>{{ user.id }}</td>
					<td>{{ user.firstName }}</td>
					<td>{{ user.lastName }}</td>
					<td>{{ user.email }}</td>
					<td>
						{% if ('ROLE_ADMIN' in user.roles) %}
							<span class="text-primary">Administrateur</span>
						{% elseif ('ROLE_EDITOR' in user.roles) %}
							<span class="text-success">Editeur</span>
						{% else %}
							<span class="text-secondary">Client</span>
						{% endif %}
					</td>
					<td>
						{% if ('ROLE_ADMIN' in user.roles) == false %}
							{% if ('ROLE_EDITOR' in user.roles) == false %}
								<a onclick="return confirm('Voulez vous vraiment affecter ce rôle à cet utilisateur?')" href="{{ path('app_user_to_editor', {'id':user.id}) }}" class="btn btn-outline-primary">Ajouter le rôle éditeur</a>
							{% else %}
								<a onclick="return confirm('Voulez vous vraiment retirer le rôle à cet utilisateur ?')" href="{{ path('app_user_remove_editor_role', {'id':user.id}) }}" class="btn btn-outline-warning">Retirer le rôle éditeur</a>
							{% endif %}
							<a href="#" class="btn btn-danger">Supprimer</a>
						{% endif %}
					</td>
				</tr>
			{% endfor %}
		</table>
	</div>
{% endblock %}
