{% extends 'base.html.twig' %}

{% block title %}
    {{ status == 'success' ? 'Paiement Réussi' : 'Paiement Annulé' }}
{% endblock %}

{% block body %}
<style>
    .status-wrapper {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 70vh;
        font-family: 'Inter', sans-serif;
    }
    .status-card {
        background: white;
        padding: 3rem;
        border-radius: 24px;
        box-shadow: 0 15px 35px rgba(0,0,0,0.05);
        max-width: 500px;
        width: 90%;
        text-align: center;
        border: 1px solid #f1f5f9;
    }
    .icon-box {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1.5rem;
        font-size: 2rem;
    }
    /* Couleurs dynamiques */
    .bg-success { background: #f0fdf4; color: #22c55e; }
    .bg-cancel { background: #fff7ed; color: #f97316; }
    
    .btn {
        display: block;
        width: 100%;
        padding: 0.8rem;
        border-radius: 12px;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.2s;
        margin-bottom: 0.8rem;
    }
    .btn-main { background: #1e293b; color: white; }
    .btn-main:hover { background: #0f172a; transform: translateY(-1px); }
    
    .btn-outline { border: 1px solid #e2e8f0; color: #64748b; }
    .btn-outline:hover { background: #f8fafc; color: #1e293b; }
</style>

<div class="status-wrapper">
    <div class="status-card">
        
        {% if status == 'success' %}
            {# --- SECTION SUCCÈS --- #}
            <div class="icon-box bg-success">
                <svg width="40" height="40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path>
                </svg>
            </div>
            <h1 style="color: #1e293b;">Merci pour votre achat !</h1>
            <p style="color: #64748b; margin-bottom: 2rem;">
                Votre paiement a été validé. Un e-mail récapitulatif vient de vous être envoyé.
            </p>
        {% else %}
            {# --- SECTION ANNULATION --- #}
            <div class="icon-box bg-cancel">
                <svg width="40" height="40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
            </div>
            <h1 style="color: #1e293b;">Paiement interrompu</h1>
            <p style="color: #64748b; margin-bottom: 2rem;">
                La transaction a été annulée. Votre compte n'a pas été débité.
            </p>
        {% endif %}

        {# --- BOUTONS DE NAVIGATION (Toujours présents) --- #}
        <div class="actions">
            {% if status == 'cancel' %}
                <a href="{{ path('app_stripe_cancel') }}" class="btn btn-main">Réessayer le paiement</a>
            {% endif %}
            
            <a href="{{ path('app_home') }}" class="btn {{ status == 'success' ? 'btn-main' : 'btn-outline' }}">
                Continuer mes achats
            </a>
            
            <a href="{{ path('app_home') }}" class="btn btn-outline">Retourner à l'accueil</a>
        </div>

    </div>
</div>
{% endblock %}