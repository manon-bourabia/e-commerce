{% extends 'base.html.twig' %} {% block title %}Ma Commande{% endblock %} {% block body %}
<div class="container mt-4">
    <div class="row">
        {# COLONNE GAUCHE : TON FORMULAIRE #}
        <div class="col-md-8">
            <h1 class="mb-4">Commande</h1>
            <div class="card p-4 shadow-sm">
                {# On garde le data-turbo de Léa pour éviter les bugs au clic sur "Continuer" #}
                {{ form_start(form, {"attr":{'data-turbo':'false'}}) }}
                    {{ form_widget(form) }}
                    <div class="d-grid mt-4">
                        <button type="submit" class="btn btn-primary">Continuer</button>
                    </div>
                {{ form_end(form) }}
            </div>
        </div>

        {# COLONNE DROITE : TON RÉCAPITULATIF (AVEC LA VARIABLE 'CART') #}
        <div class="col-md-4 mt-5">
            <div class="card p-3 bg-light shadow-sm">
                <h4 class="mb-3">Récapitulatif</h4>
                
                <div class="mb-3">
                    {# ICI : On utilise 'cart' au lieu de 'items' #}
                    {% for item in cart %}
                        <div class="d-flex justify-content-between mb-2">
                            <span>
                                <span class="badge bg-secondary me-1">{{ item.quantity }}x</span>
                                {{ item.product.name }}
                            </span>
                            <span class="fw-bold">
                                {{ (item.product.price * item.quantity)|number_format(2, ',', ' ') }} €
                            </span>
                        </div>
                    {% endfor %}
                </div>

                <hr />
                <div class="d-flex justify-content-between">
                    <span>Montant articles :</span>
                    {# ID card-price pour que le JS puisse lire la valeur #}
                    <span class="fw-bold"><span id="card-price">{{ total }}</span> €</span>
                </div>
                
                <div class="d-flex justify-content-between mt-2">
                    <span>Frais de livraison :</span>
                    {# ID shippingCost pour que le JS puisse écrire dedans #}
                    <span class="fw-bold"><span id="shippingCost">0,00</span> €</span>
                </div>

                <hr />
                <div class="d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Total final :</h5>
                    <h5 class="text-primary mb-0 fw-bold">
                        {# ID finalTotal pour le résultat du calcul #}
                        <span id="finalTotal">{{ total }}</span> €
                    </h5>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script>
    $(document).ready(function () {
        const citySelector = $('#order_city');

        function updateShipping(cityId) {
            if (!cityId) {
                $("#shippingCost").text("0,00");
                $("#finalTotal").text($("#card-price").text());
                return;
            }

            $.ajax({
                url: '/city/' + cityId + '/shipping/cost',
                type: 'GET',
                success: function(response) {
                    let data = (typeof response === 'string') ? JSON.parse(response) : response;
                    if (parseInt(data.status) === 200) {
                        let shipping = parseFloat(data.content);
                        let totalProducts = parseFloat($('#card-price').text().replace(',', '.'));

                        $("#shippingCost").text(shipping.toFixed(2).replace('.', ','));
                        
                        let totalFinal = totalProducts + shipping;
                        $("#finalTotal").text(totalFinal.toFixed(2).replace('.', ','));
                    }
                }
            });
        }

        // Écoute le changement de ville
        citySelector.on('change', function() {
            updateShipping($(this).val());
        });

        // Lance le calcul au chargement si une ville est déjà mise
        if (citySelector.val()) {
            updateShipping(citySelector.val());
        }
    });
</script>
{% endblock %}