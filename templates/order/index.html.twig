{% extends 'base.html.twig' %} {% block title %}Commande{% endblock %} {% block
body %}
<div class="container mt-4">
    <div class="row">
        <div class="col-md-8">
            <h1 class="mb-4">Commande</h1>
            <div class="card p-4 shadow-sm">
                {{ form_start(form) }} {{ form_widget(form) }}
                <div class="d-grid mt-4">
                    <button type="submit" class="btn btn-primary">
                        Continuer
                    </button>
                </div>
                {{ form_end(form) }}
            </div>
        </div>
        <div class="col-md-4 mt-5">
    {# <div class="card p-3 bg-light shadow-sm">
        <h4 class="mb-3">Récapitulatif</h4>

        <div class="mb-3">
            {% for item in items %}
                <div class="d-flex justify-content-between mb-2">
                    <span>
                        <span class="badge bg-secondary me-1">{{ item.quantity }}x</span>
                        {{ item.product.name }}
                    </span>
                    <span class="fw-bold">
                        {{ (item.product.price * item.quantity)|number_format(2, ',', ' ') }} €
                    </span>
                </div>
            {% endfor %}
        </div> #}

        <hr />

        <div class="d-flex justify-content-between">
            <span>Montant articles :</span>
            <span class="fw-bold">{{ total|number_format(2, ',', ' ') }} €</span>
        </div>
        
        <div class="d-flex justify-content-between mt-2">
            <span>Frais de livraison :</span>
            <span id="shippingCost" class="fw-bold">0,00 €</span>
        </div>

        <hr />

        <div class="d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Total final :</h5>
            <h5 id="finalTotal" class="text-primary mb-0 fw-bold">
                {{ total|number_format(2, ',', ' ') }} €
            </h5>
        </div>
    </div>
</div>
</div>
{% endblock %}{% block javascripts %}
<script>
    $(document).ready(function () {
        const citySelector = $('#order_city');
        const cityValue = citySelector.val();

        const url = 'http://localhost:8000/city/${cityValue}/shipping/cost'

        function ajaxRequest(url) {
            $.ajax({
                url: url,
                type: 'GET',
                success: function(response) {
                    // let data = (typeof response === 'string') ? JSON.parse(response) : response;

                    // console.log("Données reçues :", data);
                    // if (data.status === 200 || data.status === "200") {
                    //     $("#shippingCost").text(data.content + " €");
                    // }

                    // let totalProducts = parseFloat("{{ total }}");
                    // let shippingCost = parseFloat(data.content);
                    // let totalFinal = totalProducts + shippingCost;

                    // $("#finalTotal").text(totalFinal.toFixed(2) + " €")
                    const newResponse = JSON.parse(response);
                    if (parseInt(newResponse.status) === 200) {
                        console.log(newResponse.status);
                        $("#shippingCost").text(newResponse.content + " €");
                    }
                },
                error: function(xhr, status, error) {
                    console.error("Erreur AJAX", error);
                }
            });
        }

        citySelector.on('change', function() {
            const cityValue = $(this).val();
            const url = `/city/${cityValue}/shipping/cost`;
            
            ajaxRequest(url);
            
            // alert("ID de la ville : " + cityValue);
        });
    });
</script>
{% endblock %}
